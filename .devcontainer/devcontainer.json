{
  "name": "NikVPN GAS Relay",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "codespaces": {
      "openPorts": [
        443,
        8080
      ],
      "repositories": {
        "${localWorkspaceFolderBasename}": {
          "permissions": {
            "contents": "write"
          }
        }
      }
    }
  },
  "forwardPorts": [
    443,
    8080
  ],
  "portsAttributes": {
    "443": {
      "label": "VLESS xHTTP",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "8080": {
      "label": "GAS Relay",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "bash .devcontainer/start.sh"
}
